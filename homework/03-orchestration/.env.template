# =============================================================================
# LLM Zoomcamp — Module 03: AI Orchestration with Kestra
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
# REQUIRED:
#   GEMINI_API_KEY       — for flows 1, 2, 4, 5, 6, embeddings, and AI Copilot
#   OPENROUTER_API_KEY   — for flow 3 (RAG with websearch via OpenRouter)
#   TAVILY_API_KEY       — for web search in flows 3, 5, 6
#
# How to get:
#   Gemini:   https://aistudio.google.com/app/apikey
#   OpenRouter: https://openrouter.ai/keys
#   Tavily:   https://tavily.com/
# =============================================================================

# --- Direct Gemini API (flows 1,2,4,5,6 + embeddings + AI Copilot) ---
export GEMINI_API_KEY=your-gemini-api-key-here

# Gemini key in base64 for Kestra secret
export SECRET_GEMINI_API_KEY=

# --- OpenRouter (flow 3 — chat via OpenAI-compatible endpoint) ---
export OPENROUTER_API_KEY=your-openrouter-api-key-here
export SECRET_OPENROUTER_API_KEY=

# --- Tavily Web Search (flows 3, 5, 6) ---
export TAVILY_API_KEY=your-tavily-api-key-here
export SECRET_TAVILY_API_KEY=
